# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Africa's Talking ──────────────────────────────────────────────────────────
# Sign up at: https://account.africastalking.com
# Use "sandbox" username + key for testing (free, no real SMS sent)
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key_here
AT_SENDER_ID=RidePamoja

# ── M-Pesa (Safaricom Daraja) ─────────────────────────────────────────────────
# Get from: https://developer.safaricom.co.ke → My Apps
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_CALLBACK_URL=https://your-railway-domain.up.railway.app/api/payments/mpesa/callback
MPESA_ENV=sandbox
